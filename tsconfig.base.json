{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@autozap/types": ["../../packages/types/src"],
      "@autozap/utils": ["../../packages/utils/src"],
      "@autozap/database": ["../../packages/database/src"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
