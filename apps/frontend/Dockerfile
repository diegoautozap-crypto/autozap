FROM node:20-alpine AS builder
WORKDIR /app

ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_TENANT_SERVICE_URL
ARG NEXT_PUBLIC_CHANNEL_SERVICE_URL
ARG NEXT_PUBLIC_MESSAGE_SERVICE_URL
ARG NEXT_PUBLIC_CONTACT_SERVICE_URL
ARG NEXT_PUBLIC_CONVERSATION_SERVICE_URL
ARG NEXT_PUBLIC_CAMPAIGN_SERVICE_URL
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ARG NEXT_PUBLIC_TENANT_ID
ARG NEXT_PUBLIC_PUSHER_KEY
ARG NEXT_PUBLIC_PUSHER_CLUSTER

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_TENANT_SERVICE_URL=$NEXT_PUBLIC_TENANT_SERVICE_URL
ENV NEXT_PUBLIC_CHANNEL_SERVICE_URL=$NEXT_PUBLIC_CHANNEL_SERVICE_URL
ENV NEXT_PUBLIC_MESSAGE_SERVICE_URL=$NEXT_PUBLIC_MESSAGE_SERVICE_URL
ENV NEXT_PUBLIC_CONTACT_SERVICE_URL=$NEXT_PUBLIC_CONTACT_SERVICE_URL
ENV NEXT_PUBLIC_CONVERSATION_SERVICE_URL=$NEXT_PUBLIC_CONVERSATION_SERVICE_URL
ENV NEXT_PUBLIC_CAMPAIGN_SERVICE_URL=$NEXT_PUBLIC_CAMPAIGN_SERVICE_URL
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_TENANT_ID=$NEXT_PUBLIC_TENANT_ID
ENV NEXT_PUBLIC_PUSHER_KEY=$NEXT_PUBLIC_PUSHER_KEY
ENV NEXT_PUBLIC_PUSHER_CLUSTER=$NEXT_PUBLIC_PUSHER_CLUSTER

COPY package*.json ./
COPY tsconfig.base.json ./
COPY packages/ ./packages/
COPY apps/frontend/ ./apps/frontend/
RUN npm install --workspaces --include-workspace-root
RUN npm run build --workspace=@autozap/types
RUN npm run build --workspace=@autozap/utils
RUN npm run build --workspace=frontend

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/apps/frontend/.next/standalone ./
COPY --from=builder /app/apps/frontend/.next/static ./apps/frontend/.next/static
COPY --from=builder /app/apps/frontend/public ./apps/frontend/public
EXPOSE 3000
CMD ["node", "apps/frontend/server.js"]
